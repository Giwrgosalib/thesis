# Version Control
.git/
.gitignore

# Python Environments (CRITICAL: Prevents 2GB+ copy)
venv/
env/
.venv/
__pycache__/
*.pyc

# Node Modules (If dependent on local install)
node_modules/
frontend/node_modules/

# IDE settings
.vscode/
.idea/

# Backend Artifacts
*.db
*.sqlite
server.log
debug_out.txt
conversation_log.txt

# Temp files
tmp/
*.log

# Large binaries not needed for build (optional)
ngrok.exe
backend_nextgen.zip

# Heavy data directories (mounted at runtime via docker-compose volumes,
# or downloaded at first start; not embedded in image to keep it small).
# NOTE: do NOT exclude backend_nextgen/knowledge/ — that's the KnowledgeGraph
# Python module (graph_builder.py), needed at import time by the orchestrator.
data/
backend_nextgen/models/  # model weights (300+ MB each); ship via LFS or volume
docs_notes/

# Thesis sources (not needed in container)
thesis_project_refixed*/
thesis/
