# ── eBay Developer API ──────────────────────────────────────────────────────
# Obtain from https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your-client-id-here
EBAY_CLIENT_SECRET=your-client-secret-here
EBAY_DEV_ID=your-dev-id-here
EBAY_RUNAME=your-runame-here

# "PRODUCTION" or "SANDBOX"
EBAY_API_ENVIRONMENT=PRODUCTION

# Space-separated OAuth scopes (optional — defaults to browse scope)
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/ebay_ai
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/ebay_ai
MONGO_URI=mongodb://localhost:27017/ebay_ai
DB_NAME=ebay_extension_prefs
PREF_COLLECTION=user_preferences
SESSION_COLLECTION=auth_sessions
DB_CONNECTION_TIMEOUT=5000
DB_MAX_POOL_SIZE=10

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000
SESSION_EXPIRY=86400
MAX_REQUEST_SIZE=16777216
RATE_LIMIT_PER_MINUTE=60

# ── Frontend / CORS ──────────────────────────────────────────────────────────
APP_BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
FRONTEND_BUILD_DIR=../frontend/dist
